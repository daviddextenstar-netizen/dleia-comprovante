{
  "name": "ComproV",
  "short_name": "ComproV",
  "description": "Envio automático de comprovantes via WhatsApp com leitura de etiqueta por IA",
  "start_url": "./app.html",
  "scope": "./",
  "display": "standalone",
  "background_color": "#1a1a1a",
  "theme_color": "#3a3f44",
  "orientation": "portrait",
  "share_target": {
    "action": "./app.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "fotos-compartilhadas",
          "accept": ["image/*"]
        }
      ]
    }
  },
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ]
}
